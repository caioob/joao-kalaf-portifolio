{
  "name": "joaokalaf-portfolio",
  "private": true,
  "version": "0.1.0",
  "description": "Portfolio website — video editing, motion, product and graphic design",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev-local": "npx concurrently \"npm run dev\" \"npx decap-server\"",
    "images": "node scripts/generate-images.mjs",
    "build": "node scripts/generate-images.mjs && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "format": "prettier --write .",
    "check:tokens": "node scripts/check-tokens.mjs",
    "test": "NODE_OPTIONS=--no-experimental-webstorage vitest run",
    "test:watch": "NODE_OPTIONS=--no-experimental-webstorage vitest",
    "test:scripts": "vitest run --config vitest.scripts.config.js",
    "test:e2e": "node scripts/e2e-render.mjs",
    "og:image": "rsvg-convert -w 1200 -h 630 public/og-image.svg -o public/og-image.png && rsvg-convert -w 180 -h 180 public/favicon.svg -o public/apple-touch-icon.png"
  },
  "dependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@fontsource-variable/inter": "^5.2.8",
    "@tailwindcss/vite": "^4.3.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@vitejs/plugin-react": "^6.0.2",
    "concurrently": "^10.0.3",
    "eslint": "^10.4.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "playwright": "^1.61.0",
    "prettier": "^3.8.4",
    "sharp": "^0.35.1",
    "tailwindcss": "^4.3.0",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  }
}
